---
import { getCollection } from "astro:content";
import { CardGrid } from "@astrojs/starlight/components";
import { getDocsEntryHref, groupBy } from "./utils";
import type { TocEntry } from "../models/content";
import TocCard from "../components/helper/TocCard.astro";

interface Props {
    folder: string;
}

const { folder } = Astro.props;

/** Extract the first sub-folder segment of an entry id, or "" if at the root. */
function getSubFolderName(entryId: string): string {
    const segments = entryId.split("/");
    return segments.length > 2 ? segments[1] : "";
}

const pages = await getCollection(
    "docs",
    ({ id, data }) =>
        !data.sidebar.hidden &&
        data.template !== "splash" &&
        id.toLowerCase().startsWith(folder + "/"),
);

const entries: TocEntry[] = pages.map(({ id, data }) => ({
    subFolderName: getSubFolderName(id),
    slug: getDocsEntryHref(id),
    title: data.title,
}));

const groupedCollection = Object.entries(groupBy(entries, "subFolderName")).map(
    ([key, value]) => ({ key, value }),
);
---

{
    groupedCollection.map(({ key, value }) => (
        <>
            <h3>{key || "General"}</h3>
            <br />
            <CardGrid>
                {value.map((entry) => (
                    <TocCard header={entry.title} link={entry.slug} />
                ))}
            </CardGrid>
        </>
    ))
}
