---
// Note: StarlightIcon is the internal type for Starlight's icon union.
import type { StarlightIcon } from '@astrojs/starlight/types';
import { Icon } from "@astrojs/starlight/components";

// Props for the Card component
export interface Props {
    header: string;
    link: string;
    iconName: StarlightIcon;
    altText?: string;
    description?: string;
}

const { header, link, iconName, altText = "Icon", description } = Astro.props;
---

<a href={link} class="card">
    <div class="card-content">
        <div class="card-text">
            <header class="card-header">
                <p>{header}</p>
            </header>
            {description && <span class="card-description">{description}</span>}
        </div>
        <div class="icon-wrapper">
            <Icon name={iconName} label={altText} class="card-icon" />
        </div>
    </div>
</a>

<style>
    /* Basic Styles */
    .card {
        display: block;
        text-decoration: none;
        color: var(--color-text);
        background-color: var(--color-background);
        padding: 16px;
        border-radius: 8px;
        box-shadow: 0 4px 8px var(--color-card-shadow);
        transition: background-color 0.3s, box-shadow 0.3s, transform 0.3s;
    }

    .card:hover,
    .card:focus {
        background-color: var(--color-background);
        box-shadow: 0 8px 16px var(--color-card-hover-shadow);
        transform: translateY(-4px); /* Slight lift on hover */
    }

    .card-content {
        display: grid;
        grid-template-columns: 1fr auto; /* Grid with two columns */
        align-items: center; /* Align items vertically */
        gap: 16px; /* Spacing between text and icon */
    }

    .card-text {
        display: flex;
        flex-direction: column;
        gap: 8px; /* Spacing between header and description */
    }

    .card-header {
        margin: 0;
    }

    .card-description {
        font-size: 1rem;
        color: var(--color-secondary-text);
    }

    p {
        margin: 0;
        font-size: 1.2rem;
        color: var(--color-text);
    }

    .icon-wrapper {
        display: flex;
        align-items: center; /* Center the icon vertically */
        justify-content: center; /* Center the icon horizontally */
    }

    .card-icon {
        width: 40px; /* Adjust icon size as needed */
        height: 40px;
    }
</style>
